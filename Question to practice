12. Factorial of a number;

public class Factorial{

    public static int  fact(int n){
        if (n==0 || n==1)
        {
            return 1;
        }
        return n*fact(n-1);
    }
    public static void main(String [] args){
      int result= fact(5);
        System.out.println(result);
    }
}


